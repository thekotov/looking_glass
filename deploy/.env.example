# Looking Glass — environment template
# Copy to .env and adjust. Never commit .env.

# General
ENV=dev
DEBUG=true
LOG_LEVEL=INFO

# Server: Postgres connection
POSTGRES_USER=lg
POSTGRES_PASSWORD=lg
POSTGRES_DB=lookingglass
DATABASE_URL=postgresql+asyncpg://lg:lg@postgres:5432/lookingglass

# Server: Redis
REDIS_URL=redis://redis:6379/0

# Server: security
SECRET_KEY=please-rotate-me-with-openssl-rand-hex-32

# Seed admin user on first startup (only if no user with this username exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS — accepted as a JSON array via pydantic-settings
CORS_ORIGINS=["https://localhost","http://localhost:5173"]

# Agent
# host.docker.internal resolves to the Docker host IP — works on Docker Desktop (Windows/Mac)
# and on Linux when the agent compose adds the host-gateway extra_hosts entry.
# In production with host networking on Linux, use the actual server URL.
SERVER_URL=https://host.docker.internal
AGENT_HOSTNAME=
HEARTBEAT_INTERVAL=15s
POLL_INTERVAL=5s
# Self-signed cert in dev — leave true for local docker stack.
INSECURE_TLS=true
