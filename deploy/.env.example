# Looking Glass — environment template
# Copy to .env and adjust. Never commit .env.

# General
ENV=dev
DEBUG=true
LOG_LEVEL=INFO

# nginx host port binding. The docker nginx is HTTP only — terminate TLS on a
# host-level nginx (see deploy/nginx/lg.example.com.conf) when exposing the
# stack publicly. For a dev box, the defaults below publish on all interfaces;
# when running behind a host proxy, set HTTP_BIND=127.0.0.1 so only the host
# proxy can reach the container.
HTTP_PORT=8080
HTTP_BIND=0.0.0.0

# Server: Postgres connection
POSTGRES_USER=lg
POSTGRES_PASSWORD=lg
POSTGRES_DB=lookingglass
DATABASE_URL=postgresql+asyncpg://lg:lg@postgres:5432/lookingglass

# Server: Redis
REDIS_URL=redis://redis:6379/0

# Server: security
SECRET_KEY=please-rotate-me-with-openssl-rand-hex-32

# Seed admin user on first startup (only if no user with this username exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS — accepted as a JSON array via pydantic-settings.
# In production, list the public origin served by the host nginx (e.g.
# "https://lg.example.com") instead of the dev defaults.
CORS_ORIGINS=["http://localhost:8080","http://localhost:5173"]

# Agent
# host.docker.internal resolves to the Docker host IP — works on Docker Desktop (Windows/Mac)
# and on Linux when the agent compose adds the host-gateway extra_hosts entry.
# For a dev stack the agent talks plain HTTP to the docker nginx.
# In production with a host nginx terminating TLS, use the public URL
# (e.g. https://lg.example.com) and set INSECURE_TLS only if the host cert
# is self-signed.
SERVER_URL=http://host.docker.internal:8080
AGENT_HOSTNAME=
HEARTBEAT_INTERVAL=15s
POLL_INTERVAL=5s
# Skip TLS verification (self-signed host cert). Only meaningful when
# SERVER_URL is https. NEVER set in production.
INSECURE_TLS=false
